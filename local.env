# CodeKnowl local environment (DO NOT COMMIT secrets)
#
# Usage examples:
#   set -a; source local.env; set +a
#   env $(cat local.env | grep -v '^#' | xargs) uv run --project backend --extra dev -- uvicorn codeknowl.asgi:app --host 127.0.0.1 --port 8000

# ----------------------------------------------------------------------------
# Auth (choose one)
# ----------------------------------------------------------------------------
# API key auth (legacy mode). If set, clients must send x-codeknowl-api-key.
# CODEKNOWL_API_KEY=change-me

# OIDC / Keycloak auth (preferred). Enables bearer token auth and group-based RBAC.
# CODEKNOWL_AUTH_MODE=oidc
# CODEKNOWL_OIDC_ISSUER_URL=https://keycloak.example.com/realms/your-realm
# Optional: only used if your tokens include/require aud validation.
# CODEKNOWL_OIDC_AUDIENCE=codeknowl

# Group-based authorization mapping.
# CODEKNOWL_AUTHZ_GROUP_PREFIX=/codeknowl/repos
# CODEKNOWL_AUTHZ_READ_SUFFIX=read
# CODEKNOWL_AUTHZ_WRITE_SUFFIX=write
# CODEKNOWL_AUTHZ_ADMIN_GROUP=/codeknowl/admin

# ----------------------------------------------------------------------------
# Audit logging (fail-open)
# ----------------------------------------------------------------------------
# CODEKNOWL_AUDIT_ENABLED=true
# CODEKNOWL_AUDIT_SINK=stdout   # stdout|file
# CODEKNOWL_AUDIT_FILE=.codeknowl/audit.log
# CODEKNOWL_AUDIT_INCLUDE_QUERY_TEXT=false

# ----------------------------------------------------------------------------
# Poller (optional)
# ----------------------------------------------------------------------------
# If set to a positive integer, starts a background thread that periodically updates registered repos.
# CODEKNOWL_POLL_INTERVAL_SECONDS=300

# ----------------------------------------------------------------------------
# Vector store (semantic index)
# ----------------------------------------------------------------------------
# Primary mode is qdrant; file mode is a local-only fallback (tests/dev).
# CODEKNOWL_VECTOR_MODE=qdrant   # qdrant|file

# Qdrant connection (required if CODEKNOWL_VECTOR_MODE=qdrant)
# CODEKNOWL_QDRANT_BASE_URL=http://127.0.0.1:6333
# CODEKNOWL_QDRANT_API_KEY=
# CODEKNOWL_QDRANT_COLLECTION=codeknowl_chunks
# CODEKNOWL_QDRANT_TIMEOUT_SECONDS=30

# ----------------------------------------------------------------------------
# Embeddings
# ----------------------------------------------------------------------------
# Use http for real embeddings service, or hash for deterministic local dev/tests.
# CODEKNOWL_EMBED_MODE=http      # http|hash
# CODEKNOWL_EMBED_HASH_DIM=384

# OpenAI-compatible embeddings endpoint (required if CODEKNOWL_EMBED_MODE=http)
# CODEKNOWL_EMBED_BASE_URL=http://127.0.0.1:8001
# CODEKNOWL_EMBED_MODEL=your-embedding-model
# CODEKNOWL_EMBED_API_KEY=
# CODEKNOWL_EMBED_TIMEOUT_SECONDS=60
# CODEKNOWL_EMBED_EMBEDDINGS_PATH=/api/v1/embeddings

# ----------------------------------------------------------------------------
# LLM (QA ask synthesis: coding + general -> synth)
# ----------------------------------------------------------------------------
# Backward-compatible default profile used when role-specific profiles are not set.
# CODEKNOWL_LLM_BASE_URL=http://127.0.0.1:8002
# CODEKNOWL_LLM_MODEL=your-chat-model
# CODEKNOWL_LLM_API_KEY=
# CODEKNOWL_LLM_TIMEOUT_SECONDS=60
# CODEKNOWL_LLM_CHAT_COMPLETIONS_PATH=/api/v1/chat/completions
# CODEKNOWL_LLM_MODELS_PATH=/api/v1/models

# Role-specific overrides (optional)
# CODEKNOWL_LLM_CODING_BASE_URL=http://127.0.0.1:8002
# CODEKNOWL_LLM_CODING_MODEL=qwen3-coder
# CODEKNOWL_LLM_CODING_API_KEY=
# CODEKNOWL_LLM_CODING_TIMEOUT_SECONDS=60
# CODEKNOWL_LLM_CODING_CHAT_COMPLETIONS_PATH=/api/v1/chat/completions
# CODEKNOWL_LLM_CODING_MODELS_PATH=/api/v1/models

# CODEKNOWL_LLM_GENERAL_BASE_URL=http://127.0.0.1:8002
# CODEKNOWL_LLM_GENERAL_MODEL=gpt-oss-20b
# CODEKNOWL_LLM_GENERAL_API_KEY=
# CODEKNOWL_LLM_GENERAL_TIMEOUT_SECONDS=60
# CODEKNOWL_LLM_GENERAL_CHAT_COMPLETIONS_PATH=/api/v1/chat/completions
# CODEKNOWL_LLM_GENERAL_MODELS_PATH=/api/v1/models

# If not configured, synth defaults to GENERAL.
# CODEKNOWL_LLM_SYNTH_BASE_URL=http://127.0.0.1:8002
# CODEKNOWL_LLM_SYNTH_MODEL=gpt-oss-20b
# CODEKNOWL_LLM_SYNTH_API_KEY=
# CODEKNOWL_LLM_SYNTH_TIMEOUT_SECONDS=60
# CODEKNOWL_LLM_SYNTH_CHAT_COMPLETIONS_PATH=/api/v1/chat/completions
# CODEKNOWL_LLM_SYNTH_MODELS_PATH=/api/v1/models

# ----------------------------------------------------------------------------
# Reranker (optional)
# ----------------------------------------------------------------------------
# Modes: none|off|disabled, overlap|deterministic (local), http (OpenAI-compatible)
# CODEKNOWL_RERANK_MODE=none

# HTTP reranker config (required if CODEKNOWL_RERANK_MODE=http)
# CODEKNOWL_RERANK_BASE_URL=http://127.0.0.1:8003
# CODEKNOWL_RERANK_MODEL=your-reranker-model
# CODEKNOWL_RERANK_API_KEY=
# CODEKNOWL_RERANK_TIMEOUT_SECONDS=30
# CODEKNOWL_RERANK_RERANK_PATH=/api/v1/rerank

# ----------------------------------------------------------------------------
# QA evidence caps (deterministic prompt bounding)
# ----------------------------------------------------------------------------
# CODEKNOWL_QA_SEMANTIC_HITS_K=8
# CODEKNOWL_QA_HIT_MAX_CHARS=2000
# CODEKNOWL_QA_EVIDENCE_MAX_TEXT_CHARS=16000
# CODEKNOWL_QA_EVIDENCE_MAX_JSON_CHARS=40000

# ----------------------------------------------------------------------------
# Smoke tests (scripts)
# ----------------------------------------------------------------------------
# CODEKNOWL_SMOKE_REPO_PATH=/path/to/repo
# CODEKNOWL_SMOKE_DATA_DIR=/tmp/codeknowl-smoke
# CODEKNOWL_SMOKE_ACCEPTED_BRANCH=main
# CODEKNOWL_HTTP_SMOKE_DATA_DIR=/tmp/codeknowl-http-smoke
# CODEKNOWL_HTTP_SMOKE_PORT=8000
# CODEKNOWL_HTTP_SMOKE_KEEP_DATA_DIR=1
